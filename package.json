{
  "name": "vagabondage",
  "version": "1.0.0",
  "description": "Jeu de rôle en solitaire, Vagabondage permet d’incarner un protagoniste en fuite dans la campagne française.",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "parcel --dist-dir ./.dist ./src/index.html",
    "lint": "eslint --fix src/ || exit 0",
    "build": "parcel build --dist-dir ./maps ./src/index.html --public-url ./ --no-source-maps"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Viglino/vagabondage.git"
  },
  "keywords": [
    "maps",
    "game",
    "geoportail",
    "Openlayers",
    "ol"
  ],
  "author": "",
  "license": "",
  "bugs": {
    "url": "https://github.com/Viglino/vagabondage/issues"
  },
  "homepage": "https://github.com/Viglino/vagabondage#readme",
  "devDependencies": {
    "@parcel/transformer-inline-string": "^2.11.0",
    "@parcel/transformer-sass": "^2.11.0",
    "buffer": "^6.0.3",
    "parcel": "^2.11.0",
    "parcel-reporter-static-files-copy": "^1.5.3",
    "process": "^0.11.10"
  },
  "staticFiles": {
    "staticPath": "assets",
    "watcherGlob": "**"
  },
  "dependencies": {
    "file-saver": "^2.0.5",
    "font-awesome": "^4.7.0",
    "font-gis": "^1.0.5",
    "github-buttons": "^2.21.1",
    "ol": "^6.14.1",
    "ol-ext": "^4.0.14"
  }
}
